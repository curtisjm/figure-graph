# Build artifacts and dependencies — the dev container mounts the source
# and uses anonymous volumes for these, so they should never end up baked
# into the image even if the Dockerfile is later changed to COPY.
node_modules
.next
.pg-test
out
dist
build

# VCS
.git
.gitignore

# Logs and caches
*.log
.cache
.npm
.pnpm-store
tsconfig.tsbuildinfo

# Environment files — never bake secrets into an image
.env
.env.*
!.env.example

# Editor & OS noise
.vscode
.idea
.DS_Store
Thumbs.db

# Test outputs
playwright-report
test-results
coverage

# Docker meta
Dockerfile
docker-compose.yml
.dockerignore
